    "openai": "^4.86.0"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "mentraos",
    "smart-glasses",
    "philosophy",
    "ai",
    "stoicism",
    "coaching",
    "governance",
    "neuroverseos"
  ],
  "author": "NeuroverseOS",
